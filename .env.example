# NOUS — Environment variables
# Copy to .env and adjust for your setup

# Your name — used in Legacy mode responses to children/family
NOUS_OWNER_NAME=Your Name

# Network addresses — replace with your own IP addresses
NOUS_OLLAMA_URL=http://YOUR_NX_IP:11434
NOUS_WHISPER_URL=http://YOUR_NX_IP:8080/inference
NOUS_QDRANT_URL=http://localhost:6333
NOUS_NX_HOST=YOUR_USER@YOUR_NX_IP
NOUS_NX_LLAMA_URL=http://YOUR_NX_IP:8181

# LLM models
NOUS_LLM_MODEL=qwen2.5:7b
NOUS_LLM_14B=qwen3:14b
NOUS_EMBED_MODEL=nomic-embed-text

# Path to incoming directory
NOUS_INCOMING_DIR=/home/nous/incoming

# GPG key for backup encryption
NOUS_BACKUP_GPG_RECIPIENT=CHANGE_ME

# Nano/Jetson access for Gaia evaluation
NOUS_NANO_HOST=CHANGE_ME
NOUS_NANO_USER=nous
NOUS_NANO_EVAL_DEST=/home/nous/lora_v4/eval_data.json
NOUS_SSH_KEY_PATH=CHANGE_ME
NOUS_NX_MODELS_DIR=CHANGE_ME
NOUS_PROXY_ALLOWED_CLIENTS=CHANGE_ME
NOUS_OWNER_TAILSCALE_IPS=CHANGE_ME
