# NOUS — Miljøvariable
# Kopiér til .env og tilpas til din opsætning

# Dit navn — bruges i Legacy-mode svar til børn/familie
NOUS_OWNER_NAME=Dit Navn

# Netværksadresser — erstat med dine egne IP-adresser
NOUS_OLLAMA_URL=http://DIN_NX_IP:11434
NOUS_WHISPER_URL=http://DIN_NX_IP:8080/inference
NOUS_QDRANT_URL=http://localhost:6333
NOUS_NX_HOST=DIN_BRUGER@DIN_NX_IP
NOUS_NX_LLAMA_URL=http://DIN_NX_IP:8181

# LLM-modeller
NOUS_LLM_MODEL=qwen2.5:7b
NOUS_LLM_14B=qwen3:14b
NOUS_EMBED_MODEL=nomic-embed-text

# Sti til incoming-mappe
NOUS_INCOMING_DIR=/home/nous/incoming

# GPG-nøgle til backup-kryptering
NOUS_BACKUP_GPG_RECIPIENT=CHANGE_ME

# Nano/Jetson-adgang til Gaia-evaluering
NOUS_NANO_HOST=CHANGE_ME
NOUS_NANO_USER=nous
NOUS_NANO_EVAL_DEST=/home/nous/lora_v4/eval_data.json
NOUS_SSH_KEY_PATH=CHANGE_ME
NOUS_NX_MODELS_DIR=CHANGE_ME
NOUS_PROXY_ALLOWED_CLIENTS=CHANGE_ME
NOUS_OWNER_TAILSCALE_IPS=CHANGE_ME
