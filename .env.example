# NOUS Konfiguration — kopiér til .env og udfyld

# Bruger — dit navn, bruges i Legacy-mode svar
NOUS_OWNER_NAME=Dit Navn

# Hardware: IP-adresser (erstat med dine faktiske adresser)
NOUS_PI_IP=192.168.x.x
NOUS_JETSON_IP=192.168.x.x
NOUS_NX_HOST=nous@192.168.x.x

# Services
NOUS_OLLAMA_URL=http://192.168.x.x:11434
NOUS_WHISPER_URL=http://192.168.x.x:8080/inference
NOUS_QDRANT_URL=http://localhost:6333

# LLM-modeller
NOUS_LLM_MODEL=qwen2.5:7b
NOUS_LLM_14B=qwen3:14b
NOUS_EMBED_MODEL=nomic-embed-text

# Stier
NOUS_INCOMING_DIR=/home/<din-bruger>/incoming

# GPG nøgle til krypteret backup
NOUS_GPG_KEY_ID=dit-gpg-key-fingerprint

# Proxy: kommasepareret liste over tilladte klienter (blank = alle)
NOUS_ALLOWED_CLIENTS=192.168.x.x
